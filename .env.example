# Optional -- data sources
EKOSYSTEM_BASE_URL=https://datahub.ekosystem.slovensko.digital
EKOSYSTEM_API_TOKEN=

# Optional -- networking
MCP_SERVER_URL=http://localhost:8000/mcp
MCP_HOST=0.0.0.0
MCP_PORT=8000
API_MCP_SERVER_URL=http://localhost:8000/mcp
API_PORT=8001

# API — MongoDB connection (for ingestion dashboard)
API_MONGODB_URI=mongodb://uvo:changeme@mongo:27017
API_MONGODB_DATABASE=uvo_search

# Optional -- caching
CACHE_TTL_SEARCH=300
CACHE_TTL_ENTITY=3600
CACHE_TTL_DETAIL=1800

# Optional -- general
REQUEST_TIMEOUT=30.0
LOG_LEVEL=INFO

# MongoDB
MONGO_PASSWORD=changeme
MONGODB_URI=mongodb://uvo:changeme@mongo:27017

# Neo4j
NEO4J_PASSWORD=changeme
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j

# Pipeline
PIPELINE_MODE=recent

# Redis (streams, pub-sub, ITMS cache, distributed locks)
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# Per-source extractor cadence (seconds)
VESTNIK_INTERVAL_SECONDS=3600
CRZ_INTERVAL_SECONDS=3600
TED_INTERVAL_SECONDS=21600
ITMS_INTERVAL_SECONDS=3600

# Per-source extraction mode
VESTNIK_MODE=recent
CRZ_MODE=recent
TED_MODE=recent
ITMS_MODE=recent

# Cross-source dedup worker
DEDUP_INTERVAL_SECONDS=3600
DEDUP_DEBOUNCE_SECONDS=5
DEDUP_WINDOW_DAYS=30

# ITMS cache (memory or redis)
ITMS_CACHE_BACKEND=redis
ITMS_CACHE_TTL_SECONDS=604800

# Ingestor consumer
INGESTOR_BATCH_SIZE=100
STREAM_MAXLEN_APPROX=100000
